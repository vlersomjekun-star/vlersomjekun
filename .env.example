# PostgreSQL (Neon / Vercel Postgres in prod, `npx prisma dev` locale in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/vlersomjekun"
# Vetëm për `prisma migrate dev` në lokal
SHADOW_DATABASE_URL=""

# Salt per hash SHA-256 degli IP — NON cambiarlo dopo il lancio
PHONE_HASH_SALT="change-me-long-random-string"

# Secret per NextAuth (sessioni utenti) e cookie admin
AUTH_SECRET="change-me-another-long-random-string"

# Admin seed (creato da prisma/seed.ts)
ADMIN_SEED_EMAIL="admin@vlersomjekun.al"
ADMIN_SEED_PASSWORD="change-me"

# Google OAuth (opzionale in dev — se mancano, il login Google è disabilitato)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email provider: "mock" (dev, logga il link di verifica in console) | "resend" (prod)
EMAIL_PROVIDER="mock"
RESEND_API_KEY=""

# Google Places — SOLO assist-mode manuale dall'admin (bulk import vietato dai ToS Google).
# Opzionale: senza chiave, i bottoni "Kërko në Places" non appaiono.
GOOGLE_PLACES_API_KEY=""

# Base URL pubblico (per sitemap, JSON-LD, hreflang, link di verifica email)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
