# PostgreSQL (Neon / Vercel Postgres in prod, `npx prisma dev` locale in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/vlersomjekun"

# Salt per hash SHA-256 di telefoni e IP — NON cambiarlo dopo il lancio
PHONE_HASH_SALT="change-me-long-random-string"

# Secret per firmare il cookie di sessione admin
AUTH_SECRET="change-me-another-long-random-string"

# Admin seed (creato da prisma/seed.ts)
ADMIN_SEED_EMAIL="admin@vlersomjekun.al"
ADMIN_SEED_PASSWORD="change-me"

# SMS provider: "mock" (dev, logga il codice in console) | "twilio" (prod)
SMS_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# Base URL pubblico (per sitemap, JSON-LD, hreflang)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
