generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum ContentStatus {
  APPROVED
  PENDING
  REJECTED
}

enum SectorType {
  PUBLIC
  PRIVATE
}

enum FamilyLinkStatus {
  LINKED
  UNLINKED_FAMILY_DOCTOR
}

enum CreatedBy {
  ADMIN
  USER
}

enum TargetType {
  DOCTOR
  CLINIC
}

enum ReviewStatus {
  PUBLISHED
  PENDING
  REMOVED
}

enum Language {
  SQ
  EN
  IT
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum CommentStatus {
  PUBLISHED
  REMOVED
}

enum Gender {
  M
  F
}

enum MatchStatus {
  AUTO_MATCHED
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
  NEW_DOCTOR
  UNMATCHED
}

enum AddressSource {
  OSM
  PLACES_VERIFIED
  USER
  ADMIN
  CLINIC_SITE
  DOCTOR_VERIFIED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String? // null për OAuth users
  name               String?
  nickname           String? // max 30 (Zod); i detyrueshëm para veprimit të parë të mbrojtur
  emailVerified      DateTime?
  provider           AuthProvider        @default(CREDENTIALS)
  status             UserStatus          @default(ACTIVE)
  createdAt          DateTime            @default(now())
  reviews            Review[]
  comments           ReviewComment[]
  verificationTokens VerificationToken[]
  locationSuggestions LocationSuggestion[]
  doctorClaims       DoctorClaim[]
  // Mjeku i verifikuar tashmë menaxhon vetë profilin e tij (1 llogari → max 1 profil)
  claimedDoctor      Doctor?              @relation("ClaimedDoctor")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model City {
  id      String   @id @default(cuid())
  nameSq  String
  nameEn  String
  nameIt  String
  slug    String   @unique
  doctors Doctor[]
  clinics Clinic[]
  locationSuggestions LocationSuggestion[]
}

model Specialty {
  id      String   @id @default(cuid())
  nameSq  String
  nameEn  String
  nameIt  String
  slug    String   @unique
  icon    String
  doctors Doctor[]
}

model Clinic {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  cityId      String
  city        City          @relation(fields: [cityId], references: [id])
  address     String?
  phone       String?
  status      ContentStatus @default(PENDING)
  createdBy   CreatedBy     @default(USER)
  avgRating   Float         @default(0)
  reviewCount Int           @default(0)
  source      String? // p.sh. "SCRAPER", "OSM"
  sectorType  SectorType?   // PUBLIC (QSH etj.) / PRIVATE — null për klinika ekzistuese pa klasifikim
  latitude      Float?
  longitude     Float?
  addressSource AddressSource?
  googlePlaceId String? // e brendshme
  createdAt   DateTime      @default(now())
  doctors     Doctor[]
  reviews     Review[]
  doctorMatches DoctorClinicMatch[]
  osmCandidates OsmCandidate[]

  @@index([cityId, status])
}

model Doctor {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  // Mbiemri alternativ (i vajzërisë etj., p.sh. nga "Aga (Xharo)") — i brendshëm, i kërkueshëm
  alternativeLastName String?
  slug           String        @unique
  specialtyId    String
  specialty      Specialty     @relation(fields: [specialtyId], references: [id])
  clinicId       String?
  clinic         Clinic?       @relation(fields: [clinicId], references: [id])
  clinicFreeText String?
  cityId         String? // stomatologët nga USSH vijnë PA qytet
  city           City?         @relation(fields: [cityId], references: [id])
  address        String?
  phone          String?
  photoUrl       String?
  gender         Gender?
  source         String? // p.sh. "UMSH"
  sourceUrl      String?
  sourceKey      String?       @unique // hash idempotence për importet masive
  photoSourceUrl String? // vetëm referencë e brendshme — NUK shfaqet publikisht
  subSpecialty   String? // specialiteti më i saktë nga faqja e klinikës
  enrichedAt     DateTime?
  // E BRENDSHME: kurrë e ekspozuar publikisht dhe kurrë e përdorur si filtër —
  // datat e vjetra janë mungesë përditësimi e regjistrit, jo revokim licence
  licenseExpiry  DateTime?
  latitude       Float?
  longitude      Float?
  addressSource  AddressSource?
  googlePlaceId  String? // e brendshme — e vetmja gjë që ToS i Google lejon të ruhet
  // Faza 6: mjekë familjes (Mjek i Përgjithshëm) pa QSH ende — kërkon vendim admini,
  // MOS bëhet guess automatik mjek→QSH pa të dhëna reale (gabim i mundshëm i shumëzuar)
  familyLinkStatus FamilyLinkStatus?
  status         ContentStatus @default(PENDING)
  createdBy      CreatedBy     @default(USER)
  avgRating      Float         @default(0)
  reviewCount    Int           @default(0)
  createdAt      DateTime      @default(now())
  reviews        Review[]
  clinicMatches  DoctorClinicMatch[]
  locationSuggestions LocationSuggestion[]
  osmCandidates  OsmCandidate[]
  claims         DoctorClaim[]
  // I vendosur VETËM pas aprovimit admini (DoctorClaim.status APPROVED) —
  // atëherë, dhe vetëm atëherë, mjeku mund të menaxhojë vetë profilin e tij
  claimedByUserId String?      @unique
  claimedByUser   User?        @relation("ClaimedDoctor", fields: [claimedByUserId], references: [id])

  @@index([specialtyId, status])
  @@index([cityId, status])
}

// Kërkesë e një përdoruesi për të pretenduar (claim) profilin e tij si mjek.
// Miratimi është GJITHMONË njerëzor (admin) — asnjë verifikim automatik i
// identitetit (nuk kemi akses te API-të qeveritare të urdhrave profesionalë).
model DoctorClaim {
  id         String      @id @default(cuid())
  doctorId   String
  doctor     Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Kontekst nga kërkuesi për adminin: nr. licence, telefon pune, etj.
  message    String?
  status     ClaimStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime    @default(now())
  reviewedAt DateTime?

  @@unique([doctorId, userId])
  @@index([status])
}

// Sugjerime vendndodhjeje nga përdoruesit për mjekët pa qytet (USSH):
// 2+ sugjerime të pavarura që përputhen → cityId vendoset automatikisht
model LocationSuggestion {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([doctorId, userId])
}

model Review {
  id            String          @id @default(cuid())
  targetType    TargetType
  doctorId      String?
  doctor        Doctor?         @relation(fields: [doctorId], references: [id])
  clinicId      String?
  clinic        Clinic?         @relation(fields: [clinicId], references: [id])
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  rating        Int
  text          String
  visitMonth    Int
  visitYear     Int
  nickname      String // snapshot i nickname-it të user-it në momentin e krijimit (ruan edhe reviews legacy)
  language      Language
  ipHash        String
  status        ReviewStatus    @default(PUBLISHED)
  removalReason String?
  flagReason    String?
  createdAt     DateTime        @default(now())
  reports       Report[]
  comments      ReviewComment[]

  @@index([doctorId, status])
  @@index([clinicId, status])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}

model ReviewComment {
  id        String        @id @default(cuid())
  reviewId  String
  review    Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  text      String // max 500 (Zod)
  status    CommentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  reports   Report[]

  @@index([reviewId, status])
}

// Staging për scraper-at e klinikave — asgjë nuk shkruhet te Doctor pa kaluar këtu
model DoctorClinicMatch {
  id                String      @id @default(cuid())
  doctorId          String?
  doctor            Doctor?     @relation(fields: [doctorId], references: [id])
  clinicId          String
  clinic            Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  scrapedFirstName  String
  scrapedLastName   String
  scrapedSpecialty  String?
  scrapedTitle      String?
  photoSourceUrl    String?
  profileUrl        String?
  matchStatus       MatchStatus
  matchScore        Float?
  createdAt         DateTime    @default(now())

  @@unique([clinicId, scrapedFirstName, scrapedLastName])
  @@index([matchStatus])
}

model Report {
  id             String         @id @default(cuid())
  reviewId       String?
  review         Review?        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  commentId      String?
  comment        ReviewComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reason         String
  reporterIpHash String
  status         ReportStatus   @default(OPEN)
  createdAt      DateTime       @default(now())
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}

// Staging për kandidatët nga OpenStreetMap (ODbL — import masiv i ligjshëm me atribuim)
model OsmCandidate {
  id               String      @id @default(cuid())
  osmId            String      @unique // p.sh. "node/123456"
  osmType          String // node | way
  name             String
  amenity          String // dentist | doctors | clinic | hospital | healthcare:*
  address          String?
  phone            String?
  website          String?
  latitude         Float
  longitude        Float
  cityGuess        String? // slug qyteti nga addr:city ose bounding box
  matchedDoctorId  String?
  matchedDoctor    Doctor?     @relation(fields: [matchedDoctorId], references: [id])
  matchedClinicId  String?
  matchedClinic    Clinic?     @relation(fields: [matchedClinicId], references: [id])
  matchStatus      MatchStatus @default(UNMATCHED)
  matchScore       Float?
  createdAt        DateTime    @default(now())

  @@index([matchStatus])
}

// Kufiri ditor i kërkesave Google Places (assist-mode) — i qëndrueshëm në DB
model PlacesQuota {
  date  String @id // yyyy-mm-dd
  count Int    @default(0)
}
