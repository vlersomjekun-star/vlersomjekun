generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum ContentStatus {
  APPROVED
  PENDING
  REJECTED
}

enum CreatedBy {
  ADMIN
  USER
}

enum TargetType {
  DOCTOR
  CLINIC
}

enum ReviewStatus {
  PUBLISHED
  PENDING
  REMOVED
}

enum Language {
  SQ
  EN
  IT
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum CommentStatus {
  PUBLISHED
  REMOVED
}

enum Gender {
  M
  F
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String? // null për OAuth users
  name               String?
  nickname           String? // max 30 (Zod); i detyrueshëm para veprimit të parë të mbrojtur
  emailVerified      DateTime?
  provider           AuthProvider        @default(CREDENTIALS)
  status             UserStatus          @default(ACTIVE)
  createdAt          DateTime            @default(now())
  reviews            Review[]
  comments           ReviewComment[]
  verificationTokens VerificationToken[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model City {
  id      String   @id @default(cuid())
  nameSq  String
  nameEn  String
  nameIt  String
  slug    String   @unique
  doctors Doctor[]
  clinics Clinic[]
}

model Specialty {
  id      String   @id @default(cuid())
  nameSq  String
  nameEn  String
  nameIt  String
  slug    String   @unique
  icon    String
  doctors Doctor[]
}

model Clinic {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  cityId      String
  city        City          @relation(fields: [cityId], references: [id])
  address     String?
  phone       String?
  status      ContentStatus @default(PENDING)
  createdBy   CreatedBy     @default(USER)
  avgRating   Float         @default(0)
  reviewCount Int           @default(0)
  createdAt   DateTime      @default(now())
  doctors     Doctor[]
  reviews     Review[]

  @@index([cityId, status])
}

model Doctor {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  slug           String        @unique
  specialtyId    String
  specialty      Specialty     @relation(fields: [specialtyId], references: [id])
  clinicId       String?
  clinic         Clinic?       @relation(fields: [clinicId], references: [id])
  clinicFreeText String?
  cityId         String
  city           City          @relation(fields: [cityId], references: [id])
  address        String?
  phone          String?
  photoUrl       String?
  gender         Gender?
  source         String? // p.sh. "UMSH"
  sourceUrl      String?
  sourceKey      String?       @unique // hash idempotence për importet masive
  status         ContentStatus @default(PENDING)
  createdBy      CreatedBy     @default(USER)
  avgRating      Float         @default(0)
  reviewCount    Int           @default(0)
  createdAt      DateTime      @default(now())
  reviews        Review[]

  @@index([specialtyId, status])
  @@index([cityId, status])
}

model Review {
  id            String          @id @default(cuid())
  targetType    TargetType
  doctorId      String?
  doctor        Doctor?         @relation(fields: [doctorId], references: [id])
  clinicId      String?
  clinic        Clinic?         @relation(fields: [clinicId], references: [id])
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  rating        Int
  text          String
  visitMonth    Int
  visitYear     Int
  nickname      String // snapshot i nickname-it të user-it në momentin e krijimit (ruan edhe reviews legacy)
  language      Language
  ipHash        String
  status        ReviewStatus    @default(PUBLISHED)
  removalReason String?
  flagReason    String?
  createdAt     DateTime        @default(now())
  reports       Report[]
  comments      ReviewComment[]

  @@index([doctorId, status])
  @@index([clinicId, status])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}

model ReviewComment {
  id        String        @id @default(cuid())
  reviewId  String
  review    Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  text      String // max 500 (Zod)
  status    CommentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  reports   Report[]

  @@index([reviewId, status])
}

model Report {
  id             String         @id @default(cuid())
  reviewId       String?
  review         Review?        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  commentId      String?
  comment        ReviewComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reason         String
  reporterIpHash String
  status         ReportStatus   @default(OPEN)
  createdAt      DateTime       @default(now())
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}
